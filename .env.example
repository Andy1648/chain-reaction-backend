# Chain Reaction backend - environment variables
# Copy to .env for local dev (the .env is git-ignored; never commit real keys).

# Port the WebSocket/HTTP server listens on (defaults to 3001 if unset).
PORT=3001

# --- Category Blitz AI answer validation (Claude Haiku) ---
# Stage-2 fallback that judges creative answers not on the pre-built accept list.
# If this is unset, AI validation is DISABLED and the game uses list-only
# validation (it still runs fine - a startup warning is logged). Server-side only;
# never exposed to or set by the client.
ANTHROPIC_API_KEY=

# --- Legacy AI providers (aiValidator.js / gemini.js) ---
# No longer wired into Category Blitz (Haiku replaced them), kept for reference.
GROQ_API_KEY=
GEMINI_API_KEY=
